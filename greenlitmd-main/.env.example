# --- NEXT.JS CONFIG ---
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Change to https://orthren.app in production (TODO: update once DNS is configured)

# --- SUPABASE CONFIG ---
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="your-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- RESEND CONFIG ---
# Get this from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# --- ADMIN SECRETS ---
# A secure string used to access the /admin dashboard and trigger API routes
ADMIN_SECRET="your-secure-admin-password"

# A random secure string used to HMAC sign unsubscribe tokens
UNSUBSCRIBE_SECRET="your-random-secure-string"

# --- ANTHROPIC CONFIG ---
# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- UPSTASH REDIS CONFIG ---
# Required for rate limiting (/api/generate-pa) and feedback storage (/api/feedback)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# --- PRICING / STRIPE PAYMENT LINKS ---
# Manually-created Stripe Payment Links (Stripe Dashboard -> Payment Links).
# Not API-managed — no Stripe SDK, no webhooks. If unset, /pricing renders a
# disabled CTA with a mailto fallback instead of a broken link.
NEXT_PUBLIC_STRIPE_LINK_SOLO="https://buy.stripe.com/..."
NEXT_PUBLIC_STRIPE_LINK_GROUP="https://buy.stripe.com/..."
